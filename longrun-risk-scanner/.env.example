# Copy to .env in project root or set in environment.
# LLM is optional — tool works fully in local-only mode without a key.

# Master switch for LLM verification (verify / verify-scan commands)
LLM_ENABLED=false

# OpenAI-compatible API base URL (e.g. OpenAI, local proxy, Azure OpenAI resource)
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1

# Model name as understood by your provider
LLM_MODEL=gpt-4o-mini

# Name of the environment variable holding the API secret (value not stored in repo)
LLM_API_KEY_ENV=OPENAI_API_KEY

# Generation settings — keep temperature low for structured verification
LLM_TEMPERATURE=0.1

# Caps for context sent to the LLM (never whole-project dumps)
LLM_MAX_CONTEXT_LINES=120
LLM_MAX_PROJECT_REFERENCES=8
